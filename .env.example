# =============================================================================
# APPWRITE — Core (servidor + frontend)
# =============================================================================
# Endpoint da API (incluir /v1). Frontend: VITE_* expostos ao bundle — não coloque segredos em VITE_*.
APPWRITE_ENDPOINT=https://YOUR_APPWRITE_ENDPOINT/v1
VITE_APPWRITE_ENDPOINT=https://YOUR_APPWRITE_ENDPOINT/v1

# ID do projeto. O código aceita qualquer um destes nomes; use o mesmo valor em todos.
APPWRITE_PROJECT_ID=
APPWRITE_PROJECT=
VITE_APPWRITE_PROJECT=
VITE_APPWRITE_PROJECT_ID=

# API key server-side (permissões de banco). Nunca expor no frontend.
APPWRITE_API_KEY=YOUR_API_KEY_WITH_DATABASE_ACCESS

# ID do database. O código lê VITE_APPWRITE_DATABASE_ID ou APPWRITE_DATABASE_ID.
APPWRITE_DATABASE_ID=YOUR_DATABASE_ID
VITE_APPWRITE_DATABASE_ID=YOUR_DATABASE_ID
# Alias usado por algumas Cloud Functions Appwrite (sales, finance, inventory).
DB_ID=YOUR_DATABASE_ID

# =============================================================================
# APPWRITE — Coleções (IDs no console)
# =============================================================================
VITE_APPWRITE_LEADS_COLLECTION_ID=
APPWRITE_LEADS_COLLECTION_ID=
# Dia de vencimento da mensalidade no documento do LEAD (integer 1–31). Só ative depois de criar o atributo no Appwrite.
# Valores: dueDay | due_day | off (ou deixe vazio para não gravar e evitar erro "Unknown attribute").
# VITE_APPWRITE_LEAD_DUE_DAY_ATTR=dueDay
# Pagamento habitual no lead — criar no Appwrite: npm run provision:lead-payment-attrs
# Turma/horário (texto livre no lead). Crie o atributo na coleção leads antes de ativar.
# Valores: turma | class_name | off (ou deixe vazio para não gravar).
# VITE_APPWRITE_LEAD_TURMA_ATTR=turma

# Trancamento de plano anual (leads + histórico): npm run provision:plan-freeze
# leads: freeze_start, freeze_end, freeze_days_used, freeze_status, freeze_quota_year
# VITE_APPWRITE_PLAN_FREEZES_COLLECTION_ID= / APPWRITE_PLAN_FREEZES_COLLECTION_ID=
# student_payments: status `frozen` (meses em trancamento)

# Status do aluno na coleção de leads (após provision_student_status_schema.js):
# student_status (active|inactive), exit_reason, exit_date
# Na academia: student_exit_reasons (JSON array de strings)
# Régua de cobrança: dentro do JSON financeConfig da academia (collectionRules, overdueLabel) — sem atributos extras

# Linha do tempo / histórico do lead (coleção lead_events)
VITE_APPWRITE_LEAD_EVENTS_COLLECTION_ID=
APPWRITE_LEAD_EVENTS_COLLECTION_ID=

VITE_APPWRITE_ACADEMIES_COLLECTION_ID=
APPWRITE_ACADEMIES_COLLECTION_ID=

# Conversas / inbox / agente (obrigatório para WhatsApp + IA)
VITE_APPWRITE_CONVERSATIONS_COLLECTION_ID=
APPWRITE_CONVERSATIONS_COLLECTION_ID=

# Etiquetas de atendimento (FunilSection / Inbox filter)
VITE_APPWRITE_LABELS_COLLECTION_ID=
APPWRITE_LABELS_COLLECTION_ID=

# Flags de mensagens (fixadas/importantes no Inbox)
APPWRITE_MESSAGE_FLAGS_COLLECTION_ID=

# Notas internas de conversa
APPWRITE_CONVERSATION_NOTES_COLLECTION_ID=

# Notificações de nota (sininho /api/notifications) — mesmo ID no Appwrite que em conversationNotes ao criar nota
APPWRITE_NOTE_NOTIFICATIONS_COLLECTION_ID=
VITE_APPWRITE_NOTE_NOTIFICATIONS_COLLECTION_ID=

# Opcional: coleção dedicada para prompt por academia (intro/body/suffix). Se vazio, usa documento sentinel em CONVERSATIONS.
APPWRITE_SETTINGS_COLLECTION_ID=
VITE_APPWRITE_SETTINGS_COLLECTION_ID=

# Logs de uso da IA (threads / excedente / reset mensal). Crie com scripts/migrate-ai-plans-appwrite.mjs.
APPWRITE_AI_USAGE_LOGS_COLLECTION_ID=

# Estoque, aulas, tarefas, financeiro (Dashboard)
VITE_APPWRITE_STOCK_ITEMS_COLLECTION_ID=
STOCK_ITEMS_COL=

VITE_APPWRITE_CLASSES_COLLECTION_ID=
VITE_APPWRITE_TASKS_COLLECTION_ID=
APPWRITE_TASKS_COLLECTION_ID=

# Templates de tarefas (checklist desligamento / matrícula)
# Coleção task_templates: academy_id, name (128), trigger (32), items_json (4096), created_at, updated_at
VITE_APPWRITE_TASK_TEMPLATES_COLLECTION_ID=
APPWRITE_TASK_TEMPLATES_COLLECTION_ID=
# Opcional na coleção tasks: template_id, template_batch_id, template_name (string) — senão metadados ficam na description
VITE_APPWRITE_FINANCIAL_TX_COLLECTION_ID=
FINANCIAL_TX_COL=

# Coleção de mensalidades (pagamentos dos alunos)
VITE_APPWRITE_STUDENT_PAYMENTS_COL_ID=
# Atributos opcionais na coleção: paid_amount, expected_amount (float); status: paid|pending|awaiting|partial|cancelled
# node scripts/provision_student_payments_schema.js
# Opcional: após criar o espelho em FINANCIAL_TX, grava o id em `financial_tx_id` no mesmo documento de mensalidade.
# Só ative (true/1) depois de criar no Appwrite o atributo string `financial_tx_id` nessa coleção — senão o update falha.
# VITE_STUDENT_PAYMENT_WRITE_FINANCIAL_TX_REF=

VITE_APPWRITE_ACCOUNTS_COLLECTION_ID=
VITE_APPWRITE_JOURNAL_COLLECTION_ID=

VITE_APPWRITE_SALES_CREATE_FN_ID=
VITE_APPWRITE_SALES_CANCEL_FN_ID=
# Coleções de vendas (Appwrite + functions sales_create / sales_cancel)
VITE_APPWRITE_SALES_COLLECTION_ID=
VITE_APPWRITE_SALE_ITEMS_COLLECTION_ID=
SALES_COL=
SALE_ITEMS_COL=
# Movimentações de estoque (functions inventory_move, sales_cancel)
VITE_APPWRITE_STOCK_MOVES_COLLECTION_ID=
STOCK_MOVES_COL=
# Atributos STOCK_ITEMS: current_quantity, minimum_level, unit, last_updated, last_checked, notes, academy_id
# Atributos STOCK_MOVES: purchase_price, academy_id
# Academias: settings (JSON) com stockCheckSchedule e stockPurchaseExpenseCategory
# Cron: GET /api/cron/stock-inventory (CRON_SECRET) — conferência semanal + alertas de mínimo
FINANCE_TX_FN_ID=

VITE_APPWRITE_INVENTORY_MOVE_FN_ID=
VITE_APPWRITE_INVENTORY_SEED_KIMONOS_FN_ID=
VITE_APPWRITE_FINANCE_TX_FN_ID=

# =============================================================================
# ZAPSTER — WhatsApp
# =============================================================================
# Token da API Zapster (obrigatório). Alternativa aceita: ZAPSTER_TOKEN.
ZAPSTER_API_TOKEN=
# ZAPSTER_TOKEN=

# Base da API (padrão no código: https://api.zapsterapi.com). Alternativa: ZAPSTER_API_URL.
ZAPSTER_API_BASE_URL=https://api.zapsterapi.com

# Segredo compartilhado para validar POST /api/webhook/zapster (?token=, header x-webhook-token ou Authorization: Bearer).
# Nunca logar este valor. Não é JWT do Appwrite — é o segredo que você configura na Zapster e replica aqui.
ZAPSTER_WEBHOOK_TOKEN=

# Logs extra em /api/whatsapp (Vercel Runtime Logs). Valores: 1, true, yes. Alias: WHATSAPP_DEBUG.
# DEBUG_WHATSAPP_API=1
# Logs de Realtime no navegador (Inbox) fora de DEV. Valores: 1, true, yes.
# VITE_INBOX_DEBUG=1
# Alternativa sem deploy: no console do navegador execute:
# localStorage.setItem('inbox_debug','1')  // para ativar
# localStorage.removeItem('inbox_debug')   // para desativar

# =============================================================================
# ANTHROPIC — IA (Claude)
# =============================================================================
ANTHROPIC_API_KEY=

# =============================================================================
# SEGURANÇA INTERNA (server-to-server)
# =============================================================================
# Obrigatório: webhook → /api/agent/process e process → /api/agent/respond usam header x-internal-secret.
# Gerar com: openssl rand -hex 32
INTERNAL_API_SECRET=

# =============================================================================
# AUTENTIQUE — Contratos digitais (ver docs/contracts-autentique.md)
# =============================================================================
# Token da API (Bearer) — https://painel.autentique.com.br/perfil/api
AUTENTIQUE_TOKEN=
AUTENTIQUE_API_TOKEN=
# Segredo do endpoint de webhook (HMAC SHA256 no header x-autentique-signature)
# URL de produção: https://www.navefit.com/api/webhooks/autentique
AUTENTIQUE_WEBHOOK_SECRET=
# Coleções no database bjj-crm (APPWRITE_DATABASE_ID). Atributos sugeridos:
# contracts: academyId, leadId, template_id, autentique_id, name, status, sandbox, signers_links (JSON, 2048)
# contract_templates: academy_id, name, description, kind, storage_file_id, file_url, plan_names (JSON), is_default, active
# contract_signers: contract_id, autentique_public_id, autentique_document_id, email, name, phone, action, delivery_method, status
# contract_events: contract_id, autentique_event_id, autentique_document_id, event_type, payload_json (string, até 10k+)
# webhook_logs: raw_payload, event_type, signature_valid, processed, error
APPWRITE_CONTRACTS_COLLECTION_ID=
APPWRITE_CONTRACT_SIGNERS_COLLECTION_ID=
APPWRITE_CONTRACT_EVENTS_COLLECTION_ID=
APPWRITE_WEBHOOK_LOGS_COLLECTION_ID=
# IDs fixos (mesmo padrão de contracts, contract_signers, etc.)
APPWRITE_CONTRACT_TEMPLATES_COLLECTION_ID=contract_templates
APPWRITE_CONTRACT_TEMPLATES_BUCKET_ID=contract_templates

# =============================================================================
# ASAAS — Cobrança (Nave)
# =============================================================================
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
# Produção típica: https://api.asaas.com/v3
# Token no painel Asaas para validar webhooks (header asaas-access-token ou x-asaas-access-token)
ASAAS_WEBHOOK_SECRET=

# Coleções de billing no mesmo database Appwrite (ver comentários abaixo em Billing).
APPWRITE_BILLING_SUBSCRIPTIONS_COLLECTION_ID=
APPWRITE_BILLING_PAYMENTS_COLLECTION_ID=
APPWRITE_BILLING_IDEMPOTENCY_COLLECTION_ID=

# Plano beta único — valor mensal em R$ (padrão 297).
ASAAS_PLAN_BETA_VALUE=297

# =============================================================================
# URLs PÚBLICAS (dispatch interno / webhooks)
# =============================================================================
# URL canônica do deploy (ex.: https://seuapp.vercel.app). Usado por agent/process e webhook para chamar /api/agent/*.
NEXT_PUBLIC_BASE_URL=
# VERCEL_URL é injetada pela Vercel automaticamente (host sem protocolo).

# =============================================================================
# MULTI-TENANT — Fallbacks (produção com várias academias: deixe vazio)
# =============================================================================
# Webhook: se instância Zapster não estiver mapeada a uma academia, usa este ID (dev apenas).
DEFAULT_ACADEMY_ID=
VITE_DEFAULT_ACADEMY_ID=

# Legado: instância Zapster quando não há outra resolvida (evitar em produção multi-tenant).
DEFAULT_INSTANCE_ID=

# =============================================================================
# CONTROL iD — Catraca / reconhecimento facial
# =============================================================================
# Chave AES-256 (mín. 32 caracteres) para criptografar senha do equipamento em academy.settings
CONTROLID_ENCRYPTION_KEY=
# Relay na rede local (ex.: http://localhost:4000) — Vercel chama este URL para falar com a catraca
CONTROLID_RELAY_URL=http://localhost:4000
CONTROLID_RELAY_SECRET=
# Frontend na recepção: API local (recomendado) e proxy legado
VITE_CONTROLID_API_BASE=http://localhost:4000
VITE_CONTROLID_PROXY_BASE=http://localhost:4000/controlid-proxy
# Bucket Appwrite para fotos dos alunos (perfil → catraca)
VITE_APPWRITE_STUDENT_PHOTOS_BUCKET_ID=

# =============================================================================
# CRONS (opcional)
# =============================================================================
# GET /api/leads/cron-* (header x-cron-secret ou ?secret=) e GET /api/cron/reset-usage (Authorization: Bearer).
CRON_SECRET=seu_secret_aqui

# =============================================================================
# APP — Comportamento
# =============================================================================
# Duração do handoff humano em horas (padrão 6). Alinhar VITE_ com o servidor se alterar.
# HUMAN_HANDOFF_HOURS=6
# VITE_HUMAN_HANDOFF_HOURS=6

# true no build = trial cobrança no login/checkout; false = só prévia no front.
VITE_BILLING_ENABLED=false
BILLING_ENABLED=false

# =============================================================================
# Billing Asaas — esquema das collections (crie no console e copie os IDs)
# =============================================================================
# store_subscriptions: storeId (string, unique), status, currentPeriodEnd, cancelAtPeriodEnd, asaasCustomerId, asaasSubscriptionId, taxDocumentDigits, planSlug (opcional).
# subscription_payments: asaasPaymentId (unique), storeId, value, billingType, paidAt, asaasSubscriptionId.
# billing_idempotency_keys: key (unique), storeId, planSlug, billingType, paymentLinkUrl, asaasCustomerId, asaasSubscriptionId.
