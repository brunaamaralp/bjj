VITE_APPWRITE_ENDPOINT=https://YOUR_APPWRITE_ENDPOINT/v1
VITE_APPWRITE_PROJECT=YOUR_PROJECT_ID
VITE_APPWRITE_DATABASE_ID=YOUR_DATABASE_ID
VITE_APPWRITE_LEADS_COLLECTION_ID=YOUR_LEADS_COLLECTION_ID
VITE_APPWRITE_ACADEMIES_COLLECTION_ID=YOUR_ACADEMIES_COLLECTION_ID
VITE_APPWRITE_STOCK_ITEMS_COLLECTION_ID=YOUR_STOCK_ITEMS_COLLECTION_ID
VITE_APPWRITE_CLASSES_COLLECTION_ID=YOUR_CLASSES_COLLECTION_ID
VITE_APPWRITE_TASKS_COLLECTION_ID=YOUR_TASKS_COLLECTION_ID
VITE_APPWRITE_FINANCIAL_TX_COLLECTION_ID=YOUR_FINANCIAL_TX_COLLECTION_ID
VITE_APPWRITE_INVENTORY_MOVE_FN_ID=YOUR_INVENTORY_MOVE_FUNCTION_ID
VITE_APPWRITE_SALES_CREATE_FN_ID=YOUR_SALES_CREATE_FUNCTION_ID
VITE_APPWRITE_SALES_CANCEL_FN_ID=YOUR_SALES_CANCEL_FUNCTION_ID
VITE_APPWRITE_INVENTORY_SEED_KIMONOS_FN_ID=YOUR_INVENTORY_SEED_FUNCTION_ID
VITE_APPWRITE_FINANCE_TX_FN_ID=YOUR_FINANCE_TX_FUNCTION_ID

APPWRITE_ENDPOINT=https://YOUR_APPWRITE_ENDPOINT/v1
APPWRITE_PROJECT=YOUR_PROJECT_ID
APPWRITE_API_KEY=YOUR_API_KEY_WITH_DATABASE_ACCESS
DB_ID=YOUR_DATABASE_ID
STOCK_ITEMS_COL=YOUR_STOCK_ITEMS_COLLECTION_ID
SALES_COL=YOUR_SALES_COLLECTION_ID
SALE_ITEMS_COL=YOUR_SALE_ITEMS_COLLECTION_ID
STOCK_MOVES_COL=YOUR_STOCK_MOVES_COLLECTION_ID
FINANCIAL_TX_COL=YOUR_FINANCIAL_TX_COLLECTION_ID
FINANCE_TX_FN_ID=YOUR_FINANCE_TX_FUNCTION_ID

# Segredo para GET /api/leads/cron-confirmacao e GET /api/leads/cron-aniversario (header x-cron-secret ou ?secret=)
# Também usado por GET /api/cron/reset-usage (Authorization: Bearer CRON_SECRET).
CRON_SECRET=seu_secret_aqui

# Logs de uso da IA (threads / excedente / reset mensal). Crie a coleção com scripts/migrate-ai-plans-appwrite.mjs.
APPWRITE_AI_USAGE_LOGS_COLLECTION_ID=

# Dev/demo/mono-tenant: academia padrão usada como fallback em várias rotas e no webhook Zapster
# quando instanceId está ausente ou não há documento com esse zapster_instance_id. Em produção
# multi-tenant deixe vazio: mensagens de instância não mapeada são descartadas (motivo academia_nao_encontrada).
# VITE_DEFAULT_ACADEMY_ID= mesmo efeito se o build expuser a variável ao cliente.
DEFAULT_ACADEMY_ID=

# Opcional: duração do handoff humano (padrão 6). No front, defina VITE_ com o mesmo valor para os textos do Inbox.
# HUMAN_HANDOFF_HOURS=6
# VITE_HUMAN_HANDOFF_HOURS=6

# true no build = trial no login, checkout, status e redirecionamento para /planos quando inativo.
# Omitir ou false = só prévia no front (formulário visível, sem chamar APIs de cobrança).
VITE_BILLING_ENABLED=false

# Servidor (Vercel Functions / API): deve ficar alinhado ao front ao ligar a cobrança.
BILLING_ENABLED=false

# Billing Asaas — 3 collections no MESMO database Appwrite do app (crie no console e copie os IDs).
# store_subscriptions: storeId (string, unique), status (string), currentPeriodEnd (datetime, opcional),
#   cancelAtPeriodEnd (boolean), asaasCustomerId, asaasSubscriptionId, taxDocumentDigits (string, opcional).
#   Índice único em storeId recomendado.
# subscription_payments: asaasPaymentId (string, unique), storeId, value (string), billingType, paidAt (datetime), asaasSubscriptionId.
# billing_idempotency_keys: key (string, unique), storeId, planSlug, billingType, paymentLinkUrl (string longo),
#   asaasCustomerId, asaasSubscriptionId.
APPWRITE_BILLING_SUBSCRIPTIONS_COLLECTION_ID=
APPWRITE_BILLING_PAYMENTS_COLLECTION_ID=
APPWRITE_BILLING_IDEMPOTENCY_COLLECTION_ID=

# Asaas — https://docs.asaas.com/
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
# Token configurado no painel Asaas para validar webhooks (header asaas-access-token)
ASAAS_WEBHOOK_SECRET=

# Valores dos planos do app (BRL). Opcional: defaults no código.
# ASAAS_PLAN_MONTHLY_VALUE=99.90
# ASAAS_PLAN_ANNUAL_VALUE=999.00
