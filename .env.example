# =============================================================================
# APPWRITE — Core (servidor + frontend)
# =============================================================================
# Endpoint da API (incluir /v1). Frontend: VITE_* expostos ao bundle — não coloque segredos em VITE_*.
APPWRITE_ENDPOINT=https://YOUR_APPWRITE_ENDPOINT/v1
VITE_APPWRITE_ENDPOINT=https://YOUR_APPWRITE_ENDPOINT/v1

# ID do projeto. O código aceita qualquer um destes nomes; use o mesmo valor em todos.
APPWRITE_PROJECT_ID=
APPWRITE_PROJECT=
VITE_APPWRITE_PROJECT=
VITE_APPWRITE_PROJECT_ID=

# API key server-side (permissões de banco). Nunca expor no frontend.
APPWRITE_API_KEY=YOUR_API_KEY_WITH_DATABASE_ACCESS

# ID do database. O código lê VITE_APPWRITE_DATABASE_ID ou APPWRITE_DATABASE_ID.
APPWRITE_DATABASE_ID=YOUR_DATABASE_ID
VITE_APPWRITE_DATABASE_ID=YOUR_DATABASE_ID
# Alias usado por algumas Cloud Functions Appwrite (sales, finance, inventory).
DB_ID=YOUR_DATABASE_ID

# =============================================================================
# APPWRITE — Coleções (IDs no console)
# =============================================================================
VITE_APPWRITE_LEADS_COLLECTION_ID=
APPWRITE_LEADS_COLLECTION_ID=

# Linha do tempo / histórico do lead (coleção lead_events)
VITE_APPWRITE_LEAD_EVENTS_COLLECTION_ID=
APPWRITE_LEAD_EVENTS_COLLECTION_ID=

VITE_APPWRITE_ACADEMIES_COLLECTION_ID=
APPWRITE_ACADEMIES_COLLECTION_ID=

# Conversas / inbox / agente (obrigatório para WhatsApp + IA)
VITE_APPWRITE_CONVERSATIONS_COLLECTION_ID=
APPWRITE_CONVERSATIONS_COLLECTION_ID=

# Etiquetas de atendimento (FunilSection / Inbox filter)
VITE_APPWRITE_LABELS_COLLECTION_ID=
APPWRITE_LABELS_COLLECTION_ID=

# Flags de mensagens (fixadas/importantes no Inbox)
APPWRITE_MESSAGE_FLAGS_COLLECTION_ID=

# Notas internas de conversa
APPWRITE_CONVERSATION_NOTES_COLLECTION_ID=

# Opcional: coleção dedicada para prompt por academia (intro/body/suffix). Se vazio, usa documento sentinel em CONVERSATIONS.
APPWRITE_SETTINGS_COLLECTION_ID=
VITE_APPWRITE_SETTINGS_COLLECTION_ID=

# Logs de uso da IA (threads / excedente / reset mensal). Crie com scripts/migrate-ai-plans-appwrite.mjs.
APPWRITE_AI_USAGE_LOGS_COLLECTION_ID=

# Estoque, aulas, tarefas, financeiro (Dashboard)
VITE_APPWRITE_STOCK_ITEMS_COLLECTION_ID=
STOCK_ITEMS_COL=

VITE_APPWRITE_CLASSES_COLLECTION_ID=
VITE_APPWRITE_TASKS_COLLECTION_ID=
VITE_APPWRITE_FINANCIAL_TX_COLLECTION_ID=
FINANCIAL_TX_COL=

VITE_APPWRITE_ACCOUNTS_COLLECTION_ID=
VITE_APPWRITE_JOURNAL_COLLECTION_ID=

VITE_APPWRITE_SALES_CREATE_FN_ID=
VITE_APPWRITE_SALES_CANCEL_FN_ID=
SALES_COL=
SALE_ITEMS_COL=
STOCK_MOVES_COL=
FINANCE_TX_FN_ID=

VITE_APPWRITE_INVENTORY_MOVE_FN_ID=
VITE_APPWRITE_INVENTORY_SEED_KIMONOS_FN_ID=
VITE_APPWRITE_FINANCE_TX_FN_ID=

# =============================================================================
# ZAPSTER — WhatsApp
# =============================================================================
# Token da API Zapster (obrigatório). Alternativa aceita: ZAPSTER_TOKEN.
ZAPSTER_API_TOKEN=
# ZAPSTER_TOKEN=

# Base da API (padrão no código: https://api.zapsterapi.com). Alternativa: ZAPSTER_API_URL.
ZAPSTER_API_BASE_URL=https://api.zapsterapi.com

# Segredo compartilhado para validar POST /api/webhook/zapster (?token=, header x-webhook-token ou Authorization: Bearer).
# Nunca logar este valor. Não é JWT do Appwrite — é o segredo que você configura na Zapster e replica aqui.
ZAPSTER_WEBHOOK_TOKEN=

# Opcional / legado: instância padrão quando não há zapster_instance_id na academia.
ZAPSTER_INSTANCE_ID=

# =============================================================================
# ANTHROPIC — IA (Claude)
# =============================================================================
ANTHROPIC_API_KEY=

# =============================================================================
# SEGURANÇA INTERNA (server-to-server)
# =============================================================================
# Obrigatório: webhook → /api/agent/process e process → /api/agent/respond usam header x-internal-secret.
# Gerar com: openssl rand -hex 32
INTERNAL_API_SECRET=

# =============================================================================
# ASAAS — Cobrança (Nave)
# =============================================================================
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
# Produção típica: https://api.asaas.com/v3
# Token no painel Asaas para validar webhooks (header asaas-access-token ou x-asaas-access-token)
ASAAS_WEBHOOK_SECRET=

# Coleções de billing no mesmo database Appwrite (ver comentários abaixo em Billing).
APPWRITE_BILLING_SUBSCRIPTIONS_COLLECTION_ID=
APPWRITE_BILLING_PAYMENTS_COLLECTION_ID=
APPWRITE_BILLING_IDEMPOTENCY_COLLECTION_ID=

# Plano beta único — valor mensal em R$ (padrão 297).
ASAAS_PLAN_BETA_VALUE=297

# =============================================================================
# URLs PÚBLICAS (dispatch interno / webhooks)
# =============================================================================
# URL canônica do deploy (ex.: https://seuapp.vercel.app). Usado por agent/process e webhook para chamar /api/agent/*.
NEXT_PUBLIC_BASE_URL=
# VERCEL_URL é injetada pela Vercel automaticamente (host sem protocolo).

# =============================================================================
# MULTI-TENANT — Fallbacks (produção com várias academias: deixe vazio)
# =============================================================================
# Webhook: se instância Zapster não estiver mapeada a uma academia, usa este ID (dev apenas).
DEFAULT_ACADEMY_ID=
VITE_DEFAULT_ACADEMY_ID=

# Legado: instância Zapster quando não há outra resolvida (evitar em produção multi-tenant).
DEFAULT_INSTANCE_ID=

# =============================================================================
# CRONS (opcional)
# =============================================================================
# GET /api/leads/cron-* (header x-cron-secret ou ?secret=) e GET /api/cron/reset-usage (Authorization: Bearer).
CRON_SECRET=seu_secret_aqui

# =============================================================================
# APP — Comportamento
# =============================================================================
# Duração do handoff humano em horas (padrão 6). Alinhar VITE_ com o servidor se alterar.
# HUMAN_HANDOFF_HOURS=6
# VITE_HUMAN_HANDOFF_HOURS=6

# true no build = trial cobrança no login/checkout; false = só prévia no front.
VITE_BILLING_ENABLED=false
BILLING_ENABLED=false

# =============================================================================
# Billing Asaas — esquema das collections (crie no console e copie os IDs)
# =============================================================================
# store_subscriptions: storeId (string, unique), status, currentPeriodEnd, cancelAtPeriodEnd, asaasCustomerId, asaasSubscriptionId, taxDocumentDigits, planSlug (opcional).
# subscription_payments: asaasPaymentId (unique), storeId, value, billingType, paidAt, asaasSubscriptionId.
# billing_idempotency_keys: key (unique), storeId, planSlug, billingType, paymentLinkUrl, asaasCustomerId, asaasSubscriptionId.
