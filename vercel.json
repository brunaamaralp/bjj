{
  "headers": [
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ],
  "rewrites": [
    { "source": "/api/billing/:action(.*)", "destination": "/api/billing.js?action=$1" },
    { "source": "/api/agent/:action(.*)", "destination": "/api/agent.js?action=$1" },
    { "source": "/api/settings/ai-prompt", "destination": "/api/agent.js?route=ai-prompt" },
    { "source": "/api/settings/prompt-preview", "destination": "/api/agent.js?route=prompt-preview" },
    { "source": "/api/generate-prompt", "destination": "/api/agent.js?route=generate-prompt" },
    { "source": "/api/academies/create", "destination": "/api/agent.js?route=academy-create" },
    { "source": "/api/team/members", "destination": "/api/agent.js?route=team-members" },
    { "source": "/api/webhook/zapster", "destination": "/api/whatsapp.js?route=webhook" },
    { "source": "/api/zapster/instances", "destination": "/api/whatsapp.js?route=instances" },
    { "source": "/api/conversations", "destination": "/api/conversations.js" },
    { "source": "/api/conversations/:phone(.*)", "destination": "/api/conversations.js?phone=$1" },
    { "source": "/api/message-flags/:message_id(.*)", "destination": "/api/conversations.js?route=message-flags&message_id=$1" },
    { "source": "/api/message-flags", "destination": "/api/conversations.js?route=message-flags" },
    { "source": "/api/tasks/:id(.*)", "destination": "/api/tasks.js?id=$1" },
    { "source": "/api/tasks", "destination": "/api/tasks.js" },
    { "source": "/api/task-templates/:id(.*)", "destination": "/api/tasks.js?route=task-templates&id=$1" },
    { "source": "/api/task-templates", "destination": "/api/tasks.js?route=task-templates" },
    { "source": "/api/conversation-notes/:note_id(.*)", "destination": "/api/conversations.js?route=notes&note_id=$1" },
    { "source": "/api/conversation-notes", "destination": "/api/conversations.js?route=notes" },
    { "source": "/api/public-enrollment", "destination": "/api/leads.js?route=public-enrollment" },
    { "source": "/api/public-enrollment-config", "destination": "/api/leads.js?route=public-enrollment-config" },
    { "source": "/api/control-id/status", "destination": "/api/leads.js?route=controlid_status" },
    { "source": "/api/control-id/attendance", "destination": "/api/leads.js?route=control-id-attendance" },
    { "source": "/api/control-id/sync-all", "destination": "/api/leads.js?route=controlid_sync_all" },
    { "source": "/api/academy/settings", "destination": "/api/agent.js?route=academy-settings" },
    { "source": "/api/leads/:id(.*)", "destination": "/api/leads.js?id=$1" },
    { "source": "/v1/webhooks/asaas", "destination": "/api/webhooks.js?provider=asaas" },
    { "source": "/api/webhooks/autentique", "destination": "/api/webhooks.js?provider=autentique" },
    { "source": "/api/contracts", "destination": "/api/contracts.js" },
    { "source": "/api/contracts/:id", "destination": "/api/contracts.js?id=$1" },
    { "source": "/api/contract-templates/:id(.*)", "destination": "/api/contracts.js?route=templates&id=$1" },
    { "source": "/api/contract-templates", "destination": "/api/contracts.js?route=templates" },
    { "source": "/api/notifications/:action(.*)", "destination": "/api/conversations.js?route=notifications/$1" },
    { "source": "/api/notifications", "destination": "/api/conversations.js?route=notifications" },
    { "source": "/api/cron/automations", "destination": "/api/cron/reset-usage.js?action=automations" },
    { "source": "/api/cron/tasks-due", "destination": "/api/cron/reset-usage.js?action=tasks-due" },
    { "source": "/api/cron/collection-overdue", "destination": "/api/cron/reset-usage.js?action=collection-overdue" },
    { "source": "/api/inventory", "destination": "/api/leads.js?route=inventory" },
    { "source": "/api/inventory/adjust", "destination": "/api/leads.js?route=inventory" },
    { "source": "/api/inventory/report", "destination": "/api/leads.js?route=inventory&report=1" },
    { "source": "/api/inventory/movements/conciliation", "destination": "/api/leads.js?route=inventory&conciliation=1" },
    { "source": "/api/inventory/movements", "destination": "/api/leads.js?route=inventory&movements=1" },
    { "source": "/api/products", "destination": "/api/leads.js?route=products" },
    { "source": "/api/sales", "destination": "/api/leads.js?hub=sales" },
    { "source": "/api/cron/stock-inventory", "destination": "/api/cron/reset-usage.js?action=stock-inventory" },
    { "source": "/api/cron/plan-freeze", "destination": "/api/cron/reset-usage.js?action=plan-freeze" },
    { "source": "/api/cron/attendance-retention", "destination": "/api/cron/reset-usage.js?action=attendance-retention" },
    { "source": "/api/cron/generate-class-slots", "destination": "/api/cron/reset-usage.js?action=generate-class-slots" },
    { "source": "/api/cron/mark-booking-no-shows", "destination": "/api/cron/reset-usage.js?action=mark-booking-no-shows" },
    { "source": "/api/students/freeze", "destination": "/api/leads.js?route=students&action=freeze" },
    { "source": "/api/students/deactivate", "destination": "/api/leads.js?route=students&action=deactivate" },
    { "source": "/api/students/collection-snooze", "destination": "/api/leads.js?route=students&action=collection-snooze" },
    { "source": "/api/students/plan-freezes", "destination": "/api/leads.js?route=students&action=plan-freezes" },
    { "source": "/api/student-payments", "destination": "/api/finance.js?route=student-payments" },
    { "source": "/api/finance-tx", "destination": "/api/finance.js?route=tx" },
    { "source": "/api/finance/summary", "destination": "/api/finance.js?route=summary" },
    { "source": "/api/finance/closing", "destination": "/api/finance.js?route=closing" },
    { "source": "/api/finance/forecast", "destination": "/api/finance.js?route=forecast" },
    { "source": "/api/bank-reconciliation", "destination": "/api/finance.js?finance_hub=bank-reconciliation" },
    { "source": "/api/reports-light", "destination": "/api/reports.js?route=light" },
    { "source": "/api/reports/by-operator", "destination": "/api/reports.js?route=by-operator" },
    { "source": "/api/reports/by-student", "destination": "/api/reports.js?route=by-student" },
    { "source": "/api/reports/audit-feed", "destination": "/api/reports.js?route=audit-feed" },
    { "source": "/api/reports/attendance-retention", "destination": "/api/reports.js?route=attendance-retention" },
    { "source": "/api/reports/attendance-frequency", "destination": "/api/reports.js?route=attendance-frequency" },
    { "source": "/api/students/retention-action", "destination": "/api/leads.js?route=students&action=retention-action" },
    { "source": "/api/students/list", "destination": "/api/leads.js?route=students&action=list" },
    { "source": "/api/students/:id/profile", "destination": "/api/leads.js?route=students&action=profile&student_id=$1" },
    { "source": "/api/bookings/slots", "destination": "/api/leads.js?route=bookings&action=list-slots" },
    { "source": "/api/bookings/list", "destination": "/api/leads.js?route=bookings&action=list-bookings" },
    { "source": "/api/bookings/create", "destination": "/api/leads.js?route=bookings&action=create" },
    { "source": "/api/bookings/cancel", "destination": "/api/leads.js?route=bookings&action=cancel" },
    { "source": "/api/bookings/checkin", "destination": "/api/leads.js?route=bookings&action=checkin" },
    { "source": "/api/academy/whatsapp-templates", "destination": "/api/agent.js?route=whatsapp-templates" },

    { "source": "/((?!api/|assets/|sw\\.js|workbox-|manifest\\.webmanifest|favicon-|apple-touch-icon|navi-icon|pwa-).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/reset-usage",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/cron/reset-usage",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/automations",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/automations-frequent",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/tasks-due",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/collection-overdue",
      "schedule": "30 11 * * *"
    },
    {
      "path": "/api/cron/stock-inventory",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/plan-freeze",
      "schedule": "15 6 * * *"
    },
    {
      "path": "/api/cron/reset-usage?action=billing-reconcile",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/reset-usage?action=finance-pending-alert",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/reset-usage?action=sales-reconcile",
      "schedule": "30 7 * * *"
    },
    {
      "path": "/api/cron/reset-usage?action=student-payment-reconcile",
      "schedule": "45 7 * * *"
    },
    {
      "path": "/api/cron/reset-usage?action=finance-recurrence",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/reset-usage?action=finance-settle-scheduled",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/reset-usage?action=finance-whatsapp-alerts",
      "schedule": "45 11 * * *"
    },
    {
      "path": "/api/leads/cron-aniversario",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/attendance-retention",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/generate-class-slots",
      "schedule": "30 5 * * *"
    },
    {
      "path": "/api/cron/mark-booking-no-shows",
      "schedule": "0 3 * * *"
    }
  ]
}
